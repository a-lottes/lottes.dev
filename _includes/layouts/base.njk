<!doctype html>
<html lang="{{ page.lang }}" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="format-detection" content="telephone=no,date=no,address=no,email=no,url=no">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

  <meta name="description" content="{{ description or metadata.description }}">
  <meta name="theme-color" content="#fdfdfc" media="(prefers-color-scheme: light)">
  <meta name="theme-color" content="#131316" media="(prefers-color-scheme: dark)">
  <link rel="apple-touch-icon" href="/img/logo_lottes_alt.png">
  <link rel="icon" href="/img/logo_claim.svg" type="image/svg+xml">
  <link rel="icon" href="/img/logo_lottes_alt.png" type="image/png">

  {#- Atom and JSON feeds included by default #}
  <link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}">
  <link rel="alternate" href="/feed/feed.json" type="application/json" title="{{ metadata.title }}">

  <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/source-serif-4-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin>

  {%- css %}{% include "public/css/tokens.css" %}{% endcss %}
  {%- css %}{% include "public/css/fonts.css" %}{% endcss %}
  {%- css %}{% include "public/css/base.css" %}{% endcss %}
  {%- css %}{% include "public/css/layout.css" %}{% endcss %}
  {%- css %}{% include "public/css/prose.css" %}{% endcss %}
  {%- css %}{% include "public/css/components.css" %}{% endcss %}
  {%- css %}{% include "public/css/prism-diff.css" %}{% endcss %}
  {%- css %}{% include "node_modules/prismjs/themes/prism-okaidia.css" %}{% endcss %}

  <style>{% getBundle "css" %}</style>

  <meta name="generator" content="{{ eleventy.generator }}">

  <title>{{ title or metadata.title }}</title>
</head>
<body id="top">
{% getBundle "js", "top" %}

<a class="skip-link" href="#content">{{ "skip_to_content" | i18n }}</a>

{% include "templates/header.njk" %}

<main id="content">
  {{ content | safe }}
</main>

{% include "templates/footer.njk" %}

<!-- Current page: {{ page.url | htmlBaseUrl }} -->

{% js "top" %}
  <script>
      // Apply an explicit theme choice before first paint. Visitors on the
      // system default need nothing here: the CSS media query covers them.
      (function () {
          try {
              var scheme = localStorage.getItem('scheme');
              if (scheme === 'dark' || scheme === 'light') {
                  document.documentElement.setAttribute('data-theme', scheme);
              }
          } catch (e) {}
      })();
  </script>
{% endjs %}
{% getBundle "js", "body" %}
<script src="/js/nav.js" defer></script>
<script src="/js/theme.js" defer></script>
{% if heroCanvas %}<script src="/js/network.js" defer></script>{% endif %}
<!-- Script Matomo pour le suivi des visites -->
<script type="text/javascript" src="/js/matomo.js"></script>
</body>
</html>
