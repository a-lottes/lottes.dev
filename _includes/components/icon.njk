{# Inline SVG icons, replacing the DSFR icon font.
   Usage: {% from "components/icon.njk" import icon %} {{ icon("rss") }} #}
{% macro icon(name, size = 20) %}
<svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
  {%- if name == "rss" -%}
    <path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1" fill="currentColor" stroke="none"/>
  {%- elif name == "search" -%}
    <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
  {%- elif name == "menu" -%}
    <path d="M4 6h16M4 12h16M4 18h16"/>
  {%- elif name == "close" -%}
    <path d="M18 6 6 18M6 6l12 12"/>
  {%- elif name == "chevron-down" -%}
    <path d="m6 9 6 6 6-6"/>
  {%- elif name == "sun" -%}
    <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>
  {%- elif name == "moon" -%}
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8"/>
  {%- elif name == "monitor" -%}
    <rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/>
  {%- elif name == "arrow-up" -%}
    <path d="M12 20V4M5 11l7-7 7 7"/>
  {%- elif name == "arrow-right" -%}
    <path d="M4 12h16M13 5l7 7-7 7"/>
  {%- elif name == "arrow-left" -%}
    <path d="M20 12H4M11 5l-7 7 7 7"/>
  {%- elif name == "clock" -%}
    <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
  {%- elif name == "link" -%}
    <path d="M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7l-1.7 1.7"/><path d="M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.7-1.7"/>
  {%- elif name == "mail" -%}
    <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/>
  {%- elif name == "translate" -%}
    <path d="M4 5h12M10 3v2c0 5-2.5 9-6 11M6 10c0 3.5 3 6.5 7 8"/><path d="m13 21 5-11 5 11M15.5 16h5"/>
  {%- elif name == "github" -%}
    <path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12 12 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"/>
  {%- elif name == "linkedin" -%}
    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
  {%- elif name == "x" -%}
    <path d="M4 4l16 16M20 4 4 20"/>
  {%- endif -%}
</svg>
{%- endmacro %}
