{% if not table %}{% set table = params %}{% endif %}
<table>
  {% if table.title %}<caption>{{ table.title }}</caption>{% endif %}
  <thead>
  <tr>
    {% for header in table.headers %}
      <th scope="col">{{ header }}</th>
    {% endfor %}
  </tr>
  </thead>
  <tbody>
  {% for row in table.data %}
    <tr>
      {% for col in row %}
        <td>{{ col }}</td>
      {% endfor %}
    </tr>
  {% endfor %}
  </tbody>
</table>
