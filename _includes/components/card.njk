{% from "components/icon.njk" import icon %}
{% if not card %}{% set card = params %}{% endif %}
{% set cardUrl = card.url | locale_url or card.externalUrl %}
<div class="card {{ card.addClass }}">
  {% if card.image %}
    {% if card.image.path %}
      <div class="card__img">{% imageSync card.image.path, card.image.alt %}</div>
    {% elif card.image.src %}
      <img class="card__img" src="{{ card.image.src }}" alt="{{ card.image.alt }}">
    {% endif %}
  {% endif %}

  {% if card.badges %}
    <ul class="cluster" style="list-style:none;margin:0;padding:0">
      {% for badge in card.badges %}
        <li><span class="tag">{{ badge }}</span></li>
      {% endfor %}
    </ul>
  {% endif %}

  <h3 class="card__title">
    {% if not card.externalUrl %}
      <a href="{{ cardUrl }}">{{ card.title }}</a>
    {% else %}
      <a href="{{ card.externalUrl }}" title="{{ card.title }} - {{ "new_window" | i18n }}"
         target="_blank" rel="noopener">{{ card.title }}{{ icon("arrow-right", 16) }}</a>
    {% endif %}
  </h3>

  {% if card.description %}
    <p class="card__desc">{{ card.description }}</p>
  {% endif %}

  {% if card.tags %}
    {% set tags = card.tags %}
    {% include "components/taggroup-disabled.njk" %}
  {% endif %}

  {% if card.date %}
    <p class="card__meta">
      <time class="postlist-date" datetime="{{ card.date | htmlDateString }}">
        {{ card.date | readableDate }}
      </time>
    </p>
  {% elif card.detail %}
    <p class="card__meta">{{ card.detail }}</p>
  {% endif %}

  {% if card.detailEnd %}
    <p class="card__meta">{{ card.detailEnd }}</p>
  {% endif %}
</div>
