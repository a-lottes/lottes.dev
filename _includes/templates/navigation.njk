{# Included twice (desktop bar + mobile panel); navScope keeps ids unique. #}
{% from "components/icon.njk" import icon %}
{% set scope = navScope or "main" %}
<nav class="site-nav" role="navigation" aria-label="{{ "main_menu" | i18n }}">
  {% set navigationLinks = collections.all | filterCollectionLang | eleventyNavigation %}
  <ul class="site-nav__list">
    {% for link in navigationLinks %}
      {% set linkUrl = link.url or link.externalUrl %}
      <li>
        {% if not link.children | length %}
          <a class="site-nav__link" href="{{ linkUrl }}"{% if linkUrl == page.url %} aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
        {% else %}
          <div class="disclosure">
            <button class="disclosure__button" aria-expanded="false" aria-controls="{{ scope }}-menu-{{ loop.index }}">
              {{ link.title }}{{ icon("chevron-down", 16) }}
            </button>
            <ul class="disclosure__panel" id="{{ scope }}-menu-{{ loop.index }}" hidden>
              {% for sublink in link.children %}
                {% set sublinkUrl = sublink.url or sublink.externalUrl %}
                <li>
                  <a href="{{ sublinkUrl }}"{% if sublink.externalUrl %} target="_blank" rel="noopener"{% endif %}{% if sublinkUrl == page.url %} aria-current="page"{% endif %}>
                    {{ sublink.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</nav>
