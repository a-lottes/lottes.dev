{% from "components/icon.njk" import icon %}
<div class="share" data-pagefind-ignore>
  <span class="visually-hidden">{{ "share" | i18n }}</span>
  <a class="share__link"
     href="mailto:?subject={{ "share_link_on" | i18n }} {{ metadata.url }}&body={{ title }} {{ page.url | url }}"
     title="{{ "share_by_email" | i18n }}" target="_blank" rel="noopener">
    {{ icon("mail", 16) }}{{ "share_by_email" | i18n }}
  </a>
  <button class="share__link" type="button" title="{{ "copy" | i18n }}"
          onclick="navigator.clipboard.writeText(window.location);alert('{{ "copied" | i18n }}');">
    {{ icon("link", 16) }}{{ "copy" | i18n }}
  </button>
</div>
