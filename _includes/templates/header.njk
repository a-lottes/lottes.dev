{% from "components/icon.njk" import icon %}
<header role="banner" class="site-header">
  <div class="container site-header__inner">
    {# Motto, tagline and feed link live in the footer to keep the header light. #}
    <a class="brand" href="{{ "/" | locale_url }}"
       title="{{ "home" | i18n }} - {{ metadata.title }} - {{ metadata.description }}">
      <img class="brand__logo" src="/img/logo-lottes-bw.png" alt="lottes.dev" width="1265" height="312">
    </a>

    {% set navScope = "desktop" %}
    {% include "templates/navigation.njk" %}

    <div class="site-header__tools">
      <form class="search-field" role="search" action="{{ "/search-results/" | locale_url }}">
        <label class="visually-hidden" for="search-input">{{ "search" | i18n }}</label>
        <input id="search-input" name="term" type="search" placeholder="{{ "search_placeholder" | i18n }}">
        <button type="submit" title="{{ "search" | i18n }}">
          <span class="visually-hidden">{{ "search" | i18n }}</span>
          {{ icon("search", 18) }}
        </button>
      </form>

      {% set translateScope = "header" %}
      {% include "templates/translate.njk" %}

      <button id="theme-toggle" class="icon-button" type="button"
              data-label-light="{{ "light_theme" | i18n }}"
              data-label-dark="{{ "dark_theme" | i18n }}"
              data-label-system="{{ "system" | i18n }}"
              title="{{ "display_params" | i18n }}">
        <span class="visually-hidden">{{ "display_params" | i18n }}</span>
        <span data-scheme-icon="light" hidden>{{ icon("sun", 18) }}</span>
        <span data-scheme-icon="dark" hidden>{{ icon("moon", 18) }}</span>
        <span data-scheme-icon="system" hidden>{{ icon("monitor", 18) }}</span>
      </button>

      <button id="menu-toggle" class="icon-button menu-toggle" type="button"
              aria-expanded="false" aria-controls="mobile-panel" title="{{ "menu" | i18n }}">
        <span class="visually-hidden">{{ "menu" | i18n }}</span>
        {{ icon("menu", 20) }}
      </button>
    </div>
  </div>

  <div class="mobile-panel" id="mobile-panel" hidden>
    <div class="container">
      {% set navScope = "mobile" %}
      {% include "templates/navigation.njk" %}
      <form class="search-field" role="search" action="{{ "/search-results/" | locale_url }}">
        <label class="visually-hidden" for="search-input-mobile">{{ "search" | i18n }}</label>
        <input id="search-input-mobile" name="term" type="search" placeholder="{{ "search_placeholder" | i18n }}">
        <button type="submit" title="{{ "search" | i18n }}">
          <span class="visually-hidden">{{ "search" | i18n }}</span>
          {{ icon("search", 18) }}
        </button>
      </form>
    </div>
  </div>
</header>
